        {
            "label": "frontend",
            "type": "shell",
            // "command": "cd frontend && npm run dev",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "icon": {
                "id": "vm"
            },
            "presentation": {
                // "group": "report-ia-group",
                "panel": "dedicated",
                "clear": true,
                "focus": false
            }
        },
        {
            "label": "backend",
            "type": "shell",
            // "command": "cd backend && npm run dev",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "icon": {
                "id": "server-environment"
            },
            "presentation": {
                // "group": "report-ia-group",
                "panel": "dedicated",
                "clear": true,
                "focus": true
            }
        },
        {
            "label": "gem",
            "type": "shell",
            "command": "gemini",
            "icon": {
                "id": "zap"
            },
            "presentation": {
                // "group": "report-ia-group",
                "panel": "dedicated",
                "clear": true,
                "focus": false
            }
        },
        {
            "label": "🚀 Iniciar Report IA Force",
            // "dependsOrder": "sequence",
            "dependsOn": [
                // "_delay_startup",
                "frontend",
                "backend",
                "gem"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            // "presentation": {
            //     "reveal": "always",
            //     "panel": "new"
            // },
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}